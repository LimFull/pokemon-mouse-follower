"move.desc.255" = "거품을 기세 좋게 상대에게 발사하여 공격한다. 스피드를 떨어뜨릴 때가 있다.";
"move.desc.257" = "자신의 HP를 최대 HP의 절반만큼 감소시켜 자신의 공격을 최대로 올린다.";
"move.desc.258" = "튼튼한 장막을 만들어 자신의 방어를 크게 올린다.";
"move.desc.259" = "5턴 동안 이상한 장막을 쳐서 상대로부터 받는 특수공격의 데미지를 약하게 한다.";
"move.desc.260" = "단단하고 뾰족한 날카로운 손톱으로 상대를 할퀴어서 공격한다.";
"move.desc.261" = "날카로운 앞니로 강하게 물어서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.262" = "작은 불꽃을 상대에게 발사하여 공격한다. 화상 상태로 만들 때가 있다.";
"move.desc.264" = "리드미컬한 펀치를 날려 상대를 공격한다. 혼란시킬 때가 있다.";
"move.desc.266" = "상대가 자신과 같은 기술을 배웠다면 상대만 그 기술을 사용할 수 없게 한다.";
"move.desc.267" = "깃털을 흩뿌려 상대의 몸에 휘감는다. 상대의 공격을 크게 떨어뜨린다.";
"move.desc.268" = "상대를 날려버려서 교대할 포켓몬을 끌어낸다. 야생의 경우에는 배틀이 끝난다.";
"move.desc.269" = "같은 편 전원이 공격한다. 동료 포켓몬이 많을수록 기술의 공격 횟수가 증가한다.";
"move.desc.270" = "세찬 눈보라를 상대에게 내뿜어 공격한다. 얼음 상태로 만들 때가 있다.";
"move.desc.271" = "큰 발로 상대를 짓밟아서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.272" = "폭발하는 불꽃으로 상대를 태워서 공격한다. 다음 턴은 움직일 수 없다.";
"move.desc.275" = "단단하고 날카로운 손톱으로 베어 갈라서 공격한다. 상대의 방어를 떨어뜨릴 때가 있다.";
"move.desc.276" = "공격한 상대를 화상 상태로 만들 때가 있다. 급소에도 맞기 쉽다.";
"move.desc.277" = "덫을 설치한 상자를 상대에게 건네어 공격한다. HP가 회복돼버릴 때도 있다.";
"move.desc.278" = "분노를 폭발시켜 상대를 공격한다. 자신의 HP가 적을수록 기술의 위력이 떨어진다.";
"move.desc.279" = "더러운 오물을 상대에게 내던져서 공격한다. 독 상태로 만들 때가 있다.";
"move.desc.280" = "더러운 오물을 상대에게 내던져서 공격한다. 독 상태로 만들 때가 있다.";
"move.desc.281" = "배의 무늬로 겁을 주어 상대를 마비 상태로 만든다.";
"move.desc.282" = "상대 포켓몬으로 변신하여 상대와 완전히 똑같은 기술을 사용할 수 있다.";
"move.desc.284" = "상대를 도망가게 해서 교대할 포켓몬을 끌어낸다. 야생의 경우에는 배틀이 끝난다.";
"move.desc.285" = "단단한 뼈로 상대를 세게 때려서 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.286" = "물가나 풀밭, 동굴 등 있는 장소에 맞춰서 자신의 타입을 바꾼다.";
"move.desc.287" = "귀엽게 애교 부리며 상대에게 다가가 지니고 있는 도구를 뺏는다.";
"move.desc.289" = "손에 들고 있는 뼈로 상대를 세게 때려서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.290" = "손에 들고 있는 뼈를 상대에게 날려서 날아갈 때와 돌아올 때 2회 연속 데미지를 준다.";
"move.desc.291" = "세차게 소용돌이치는 불꽃 속에 4-5턴 동안 상대를 가두어 공격한다.";
"move.desc.292" = "불꽃을 담은 펀치로 상대를 공격한다. 화상 상태로 만들 때가 있다.";
"move.desc.293" = "노래를 들은 포켓몬은 3턴이 지나면 기절한다. 교체되면 효과가 없어진다.";
"move.desc.294" = "긴 몸이나 덩굴 등을 사용해 4-5턴 동안 상대를 휘감아 공격한다.";
"move.desc.295" = "상대의 발밑에 압정을 뿌린다. 교체된 상대 포켓몬에게 데미지를 준다.";
"move.desc.296" = "땅을 흔들어서 자신의 주위에 있는 포켓몬을 공격한다. 기술의 위력이 여러모로 바뀐다.";
"move.desc.297" = "상대를 추적하는 이상한 잎사귀를 흩뿌린다. 공격은 반드시 명중한다.";
"move.desc.298" = "상대가 상태 이상이 되는 기술이나 씨뿌리기 등을 썼을 때 되받아친다.";
"move.desc.299" = "진흙 덩어리를 상대에게 내던져서 공격한다. 동시에 상대의 스피드를 떨어뜨린다.";
"move.desc.300" = "눈에 보이지 않는 굉장한 속도로 펀치를 날린다. 반드시 선제공격을 할 수 있다.";
"move.desc.301" = "상대의 공격을 전혀 받지 않는다. 연속으로 쓰면 실패하기 쉽다.";
"move.desc.302" = "몸을 둥글게 웅크려서 자신의 방어를 올린다.";
"move.desc.303" = "몸을 재빨리 회전시키며 걷어차서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.304" = "자신의 HP를 조금 깎아서 분신을 만든다. 분신은 자신의 대타가 된다.";
"move.desc.305" = "상대의 공격을 전혀 받지 않는다. 연속으로 쓰면 실패하기 쉽다.";
"move.desc.306" = "날카로운 침을 상대에게 발사해서 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.307" = "주위를 물로 흠뻑 젖게 만든다. 5턴 동안 불꽃타입의 기술을 약하게 한다.";
"move.desc.308" = "물을 기세 좋게 상대에게 발사하여 공격한다.";
"move.desc.310" = "물의 진동을 상대에게 가하여 공격한다. 상대를 혼란시킬 때가 있다.";
"move.desc.311" = "뿔이나 부리로 상대를 찔러서 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.312" = "손톱이나 낫 등으로 상대를 할퀴어서 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.313" = "기술을 쓴 뒤 상대의 공격으로 기절했을 때 공격 상대도 기절하게 한다. 연속으로 쓰면 실패한다.";
"move.desc.314" = "상대의 HP가 반드시 1만 남도록 조절하여 공격한다.";
"move.desc.315" = "고스트타입에 효과가 없는 기술이나 회피율이 높은 상대라 할지라도 공격이 맞게 된다.";
"move.desc.316" = "상대에게 받은 특수공격의 데미지를 2배로 만들어 그 상대에게 돌려준다.";
"move.desc.317" = "기술을 사용한 2턴 뒤에 상대에게 염동력의 덩어리를 보내어 공격한다.";
"move.desc.318" = "자신의 최대 HP 절반을 회복한다.";
"move.desc.319" = "조용히 정신을 통일하고 마음을 가라앉혀서 자신의 특수공격과 특수방어를 올린다.";
"move.desc.320" = "양분을 흡수하여 공격한다. 상대에게 입힌 데미지의 절반에 해당하는 HP를 회복할 수 있다.";
"move.desc.321" = "굉장한 힘을 담은 킥으로 상대를 걷어차서 공격한다.";
"move.desc.322" = "힘을 담은 펀치로 상대를 공격한다.";
"move.desc.323" = "단단하고 훌륭한 뿔로 마음껏 상대를 꿰찔러서 공격한다.";
"move.desc.324" = "기술을 쓴 포켓몬에 따라 기술의 타입이 바뀐다.";
"move.desc.325" = "강철의 발톱으로 상대를 베어 갈라 공격한다. 자신의 공격이 올라갈 때도 있다.";
"move.desc.327" = "상대가 마지막에 사용한 기술을 배틀을 하는 동안 자신의 기술로 만들 수 있다.";
"move.desc.329" = "씨가 뿌려진 상대의 HP를 매 턴 조금씩 흡수하여 자신의 HP를 회복한다.";
"move.desc.330" = "손가락을 흔들어 자신의 뇌를 자극해서 모든 기술 중 어느 하나를 날린다.";
"move.desc.331" = "잠자고 있는 상대의 꿈을 먹어 공격한다. 데미지의 절반을 HP로 회복한다.";
"move.desc.332" = "강한 산을 상대에게 끼얹어 공격한다. 상대의 특수방어를 떨어뜨릴 때가 있다.";
"move.desc.333" = "잠들어 있는 힘을 몸속에서 끌어내어 자신의 공격을 올린다.";
"move.desc.336" = "잎사귀를 칼처럼 이용해 상대를 베어 공격한다. 급소에 맞기 쉽다.";
"move.desc.337" = "배틀 중에 사용하여 없어진 자신의 지닌 물건을 재생시켜 사용할 수 있게 한다.";
"move.desc.338" = "5턴 동안 이상한 장막을 쳐서 상대로부터 받는 물리공격의 데미지를 약하게 한다.";
"move.desc.339" = "몸을 쉬게 하여 자신이 입은 독, 마비, 화상의 상태 이상을 치료한다.";
"move.desc.340" = "상대에게 기술을 받으면 그 상대에게 주는 데미지가 2배가 된다.";
"move.desc.341" = "분노의 충격파를 상대에게 부딪쳐서 공격한다. 언제나 40의 데미지를 준다.";
"move.desc.342" = "굉장한 숨결을 상대에게 내뿜어 공격한다. 마비 상태로 만들 때가 있다.";
"move.desc.343" = "신비롭고 힘센 춤을 격렬하게 춘다. 자신의 공격과 스피드를 올린다.";
"move.desc.344" = "냉기를 담은 펀치로 상대를 공격한다. 얼음 상태로 만들 때가 있다.";
"move.desc.345" = "냉동빔을 상대에게 발사하여 공격한다. 얼음 상태로 만들 때가 있다.";
"move.desc.346" = "낫이나 발톱 등으로 상대를 베어 공격한다. 연속으로 맞히면 위력이 올라간다.";
"move.desc.347" = "노도 같은 펀치로 상대를 세게 때려서 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.348" = "1턴째에 머리를 움츠려 방어를 올린다. 2턴째에 상대를 공격한다.";
"move.desc.349" = "조준을 잘 맞춰 다음 공격이 반드시 상대에게 명중하도록 한다.";
"move.desc.350" = "단단한 암석을 상대에게 발사하여 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.351" = "솜처럼 폭신폭신한 포자를 착 달라붙게 해서 상대의 스피드를 크게 떨어뜨린다.";
"move.desc.353" = "공기의 소용돌이를 발사하여 공격한다. 급소에 맞기 쉽다.";
"move.desc.430" = "강하고 무거운 주먹을 휘둘러 데미지를 준다. 자신의 스피드가 떨어진다.";
"move.desc.431" = "강철과 같은 단단한 머리로 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.432" = "눈에 보이지 않는 굉장한 속도로 상대에게 돌진한다. 반드시 선제공격할 수 있다.";
"move.desc.433" = "세차게 날뛰는 거친 파도와 같이 큰 꼬리를 흔들어서 상대를 공격한다.";
"move.desc.434" = "자신의 몸 주변을 물로 만든 베일로 덮는다. 매 턴 HP를 회복한다.";
"move.desc.436" = "몸에서 악의로 가득한 무서운 오라를 발한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.437" = "소름이 끼칠 만한 돌풍으로 상대를 공격한다. 자신의 모든 능력이 올라갈 때가 있다.";
"move.desc.438" = "상대의 몸에 위액을 내뱉는다. 달라붙은 위액은 상대의 특성 효과를 지운다.";
"move.desc.439" = "자신은 기절하지만 교대하여 나오는 포켓몬의 상태 이상과 HP를 회복한다.";
"move.desc.440" = "방어를 포기하고 상대 쪽으로 깊숙이 돌격한다. 자신의 방어와 특수방어가 떨어진다.";
"move.desc.441" = "단단한 몸통을 상대에게 부딪쳐서 공격한다. 자신도 상당한 데미지를 입는다.";
"move.desc.442" = "하늘까지 베어 가르는 공기의 칼날로 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.444" = "세차게 불어대는 바람의 소용돌이를 만들어 4턴 동안 같은 편 모두의 스피드를 올린다.";
"move.desc.445" = "능력 변화로 상대가 파워업한 만큼 기술의 위력이 올라간다.";
"move.desc.447" = "하늘을 향해 기도를 올려 5턴 동안 상대의 공격을 급소에 맞지 않게 한다.";
"move.desc.448" = "초능력으로 자신과 상대의 방어와 특수방어의 능력 변화를 교체한다.";
"move.desc.450" = "5턴 동안 기술이나 특성, 지니고 있는 도구에 의한 HP 회복을 할 수 없게 한다.";
"move.desc.451" = "그림자를 늘려 상대의 배후에서 공격한다. 반드시 선제공격할 수 있다.";
"move.desc.452" = "전기를 모은 이빨로 문다. 상대를 풀죽게 하거나 마비 상태로 만들 때가 있다.";
"move.desc.455" = "가진 힘을 모두 사용해서 상대에게 돌격한다. 다음 턴은 움직일 수 없다.";
"move.desc.457" = "마지막수단의 남은 PP가 적으면 적을수록 기술의 위력이 올라간다.";
"move.desc.459" = "독 칼날로 상대를 베어 가른다. 독 상태로 만들 때가 있고 급소에도 맞기 쉽다.";
"move.desc.461" = "냉기를 품은 이빨로 문다. 상대를 풀죽게 하거나 얼음 상태로 만들 때가 있다.";
"move.desc.462" = "얼음덩어리를 순식간에 만들어 상대에게 빠르게 쏜다. 반드시 선제공격을 할 수 있다.";
"move.desc.463" = "실체화시킨 마음의 칼날로 상대를 베어 가른다. 급소에 맞기 쉽다.";
"move.desc.464" = "초능력으로 암시를 걸어서 자신에게 걸려 있는 상태 이상을 상대에게 옮긴다.";
"move.desc.465" = "위력을 올려 상대가 쓰려고 하는 기술을 먼저 쓴다. 먼저 쓰지 않으면 실패한다.";
"move.desc.466" = "지니게 한 도구를 5턴 동안 쓸 수 없게 한다. 트레이너도 그 포켓몬에게는 도구를 쓸 수 없다.";
"move.desc.469" = "상대가 HP의 절반 정도 상처를 입고 있으면 기술의 위력이 2배가 된다.";
"move.desc.470" = "낫이나 발톱을 가위처럼 교차시키면서 상대를 베어 가른다.";
"move.desc.471" = "나무열매에서 힘을 얻어 공격한다. 지니게 한 나무열매에 따라 기술의 타입과 위력이 바뀐다.";
"move.desc.472" = "모아서 공격한다. 상대보다 나중에 공격할 수 있으면 기술의 위력은 2배가 된다.";
"move.desc.473" = "사념의 힘을 이마에 모아서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.474" = "강하게 조여 공격을 한다. 상대의 HP가 많이 남아 있을수록 위력이 올라간다.";
"move.desc.475" = "몸을 고속으로 회전시켜 몸통박치기한다. 상대보다 스피드가 낮을수록 위력은 올라간다.";
"move.desc.476" = "그림자로 만든 날카로운 발톱으로 상대를 베어 가른다. 급소에 맞기 쉽다.";
"move.desc.478" = "5턴 동안 부유나 비행타입에 땅타입의 기술이 맞게 된다. 공중으로 나는 기술도 사용할 수 없다.";
"move.desc.479" = "주먹을 흔들어 진공의 파도를 일으킨다. 반드시 선제공격을 할 수 있다.";
"move.desc.481" = "뾰족한 바위를 상대에게 꿰찔러서 공격한다. 급소에 맞기 쉽다.";
"move.desc.482" = "눈에 보이지 않는 속도로 자신과 상대가 지닌 물건을 교환한다.";
"move.desc.484" = "상대의 발밑에 대지의 힘을 방출한다. 상대의 특수방어를 떨어뜨릴 때가 있다.";
"move.desc.485" = "더러운 쓰레기를 상대에게 부딪쳐서 공격한다. 독 상태로 만들 때가 있다.";
"move.desc.486" = "단단한 껍질을 가지고 있는 큰 씨앗을 위에서 힘껏 내던져 상대를 공격한다.";
"move.desc.487" = "꼬리 등을 써서 상대를 때려 공격한다. 2회 연속으로 데미지를 준다.";
"move.desc.488" = "그 턴에 상대가 이미 데미지를 입었다면 기술의 위력은 2배가 된다.";
"move.desc.489" = "전격의 다발을 상대에게 발사한다. 전기를 모아서 자신의 특수공격을 올릴 때가 있다.";
"move.desc.490" = "부리로 공격한다. 상대가 나무열매를 지니고 있을 때 먹어서 나무열매의 효과를 받을 수 있다.";
"move.desc.491" = "순간적으로 틈을 노려 상대를 베어 버린다. 급소에 맞기 쉽다.";
"move.desc.492" = "경혈을 눌러 몸을 활성화시킨다. 능력 중 하나를 크게 올린다.";
"move.desc.493" = "전기로 만든 자력의 힘으로 허공에 뜬다. 5턴 동안 부유할 수 있다.";
"move.desc.495" = "독에 물든 촉수나 팔로 상대를 꿰찌른다. 독 상태로 만들 때가 있다.";
"move.desc.496" = "상대의 발밑에 독 압정을 뿌린다. 교체로 나온 상대 포켓몬에게 독을 퍼지게 한다.";
"move.desc.497" = "배틀 중에 기억하고 있는 기술을 모두 사용하면 그때부터 쓸 수 있는 필살기이다.";
"move.desc.498" = "굉장한 살기로 위압하면서 몸통박치기한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.501" = "단단한 진흙구슬을 상대에게 발사하여 공격한다. 명중률을 떨어뜨릴 때가 있다.";
"move.desc.502" = "공격한 뒤 굉장한 스피드로 돌아와서 교대 포켓몬과 교체한다.";
"move.desc.503" = "지니게 한 도구를 재빠르게 내던져서 공격한다. 도구에 따라 위력과 효과가 바뀐다.";
"move.desc.504" = "마음을 괴롭히는 씨앗을 심는다. 상대를 잠잘 수 없게 해서 특성을 불면으로 만든다.";
"move.desc.508" = "몸속에서 파동의 힘을 끌어내 상대에게 쏜다. 공격은 반드시 명중한다.";
"move.desc.509" = "땅에 내려와 몸을 쉬게 한다. 최대 HP의 절반만큼 HP를 회복한다.";
"move.desc.510" = "탄환처럼 빠르고 단단한 펀치를 상대에게 날린다. 반드시 선제공격을 할 수 있다.";
"move.desc.511" = "덩굴이나 촉수를 세차게 흔들어 상대를 힘껏 쳐서 공격한다.";
"move.desc.512" = "보석처럼 반짝이는 빛을 발사하여 상대를 공격한다.";
"move.desc.513" = "초능력으로 자신과 상대의 공격과 특수공격의 능력 변화를 교체한다.";
"move.desc.514" = "초능력으로 자신의 공격과 방어의 힘을 교환한다.";
"move.desc.515" = "상대보다 먼저 공격할 수 있다. 상대가 쓴 기술이 공격기술이 아니면 실패한다.";
"move.desc.516" = "방어나 판별 등을 하고 있는 상대에게 공격할 수 있다. 방어 효과를 해제시킨다.";
"move.desc.517" = "불꽃을 두르고 돌진한다. 자신도 상당한 데미지를 입는다. 화상 상태로 만들 때가 있다.";
"move.desc.519" = "새빨간 불꽃으로 자신의 주위에 있는 포켓몬을 공격한다. 화상 상태로 만들 때가 있다.";
"move.desc.521" = "눈부신 전격으로 자신의 주위에 있는 포켓몬을 공격한다. 마비 상태로 만들 때가 있다.";
"move.desc.522" = "불꽃을 두른 이빨로 문다. 상대를 풀죽게 하거나 화상 상태로 만들 때가 있다.";
"move.desc.523" = "상대에게 달라붙는 강철의 폭탄을 발사한다. 공격은 반드시 명중한다.";
"move.desc.525" = "직전에 나온 기술을 흉내 내어 같은 기술을 쓴다. 기술이 나오지 않았으면 실패한다.";
"move.desc.527" = "갈고닦은 몸에서 섬광의 힘을 상대에게 쏜다. 명중률을 떨어뜨릴 때가 있다.";
"move.desc.528" = "악타입에 효과가 없는 기술이나 회피율이 높은 상대라 할지라도 공격이 맞게 된다.";
"move.desc.529" = "물어서 공격한다. 상대가 나무열매를 지니고 있을 때 먹어서 나무열매의 효과를 받을 수 있다.";
"move.desc.530" = "진동으로 음파를 일으켜서 공격한다. 상대의 특수방어를 떨어뜨릴 때가 있다.";
"move.desc.531" = "잠듦 상태의 상대에게 큰 데미지를 준다. 대신 상대는 잠에서 깬다.";
"move.desc.534" = "수컷은 암컷을 암컷은 수컷을 유혹하여 상대의 특수공격을 크게 떨어뜨린다.";
"move.desc.535" = "상대로부터 기술을 받으면 그 상대에 대해서 기술의 위력이 2배가 된다.";
"move.desc.536" = "몸의 빛을 한곳에 모아서 힘을 방출한다. 상대의 특수방어를 떨어뜨릴 때가 있다.";
"move.desc.537" = "뾰족한 잎사귀로 상대에게 돌풍을 일으킨다. 사용하면 반동으로 자신의 특수공격이 크게 떨어진다.";
"move.desc.538" = "천공에서 운석을 상대에게 떨어뜨린다. 사용하면 반동으로 자신의 특수공격이 크게 떨어진다.";
"move.desc.539" = "큰 입으로 충격파를 일으켜서 상대를 공격한다.";
"move.desc.540" = "자신의 몸을 갈아 공기의 저항을 적게 한다. 스피드를 크게 올릴 수 있다.";
"move.desc.542" = "나쁜 일을 생각해서 머리를 활성화시킨다. 자신의 특수공격을 크게 올린다.";

