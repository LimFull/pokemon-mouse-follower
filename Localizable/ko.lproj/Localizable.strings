"move.desc.1" = "단단한 꼬리로 상대를 힘껏 쳐서 공격한다. 상대의 방어를 떨어뜨릴 때가 있다.";
"move.desc.3" = "큰 하품으로 졸음을 유도한다. 다음 턴에 상대를 잠듦 상태로 만든다.";
"move.desc.4" = "무서운 얼굴로 키스한다. 상대를 잠듦 상태로 만든다.";
"move.desc.5" = "잠듦 상태의 상대에게 악몽을 꾸게 하여 매 턴 조금씩 HP를 떨어뜨려 간다.";
"move.desc.6" = "자신의 HP를 회복한다. 날씨에 따라 회복량이 변한다.";
"move.desc.7" = "상대보다 나중에 공격한다. 그 대신 자신의 공격은 반드시 명중한다.";
"move.desc.8" = "1턴째에 파고들어 2턴째에 상대를 공격한다.";
"move.desc.9" = "2-3턴 동안 마구 난동 부려서 상대를 공격한다. 난동 부린 뒤에는 혼란에 빠진다.";
"move.desc.10" = "향기로 상대의 회피율을 크게 떨어뜨린다.";
"move.desc.11" = "귀엽게 바라보고 방심을 유도하여 상대의 공격을 크게 떨어뜨린다.";
"move.desc.12" = "5턴 동안 비를 내리게 해서 물타입 기술의 위력을 올린다. 불꽃타입의 위력은 떨어진다.";
"move.desc.13" = "이상한 빛을 상대에게 비춰 당황하게 한다. 상대를 혼란시킨다.";
"move.desc.14" = "5턴 동안 싸라기눈을 내리게 해서 얼음타입이 아닌 포켓몬 모두에게 데미지를 준다.";
"move.desc.15" = "기분 좋은 평온한 향기를 맡게 하여 같은 편 모두의 상태 이상을 회복한다.";
"move.desc.16" = "매우 많은 거품을 상대에게 내뿜어 공격한다. 상대의 스피드를 떨어뜨릴 때가 있다.";
"move.desc.17" = "상대에게 앵콜시킨 기술을 3번 연속으로 쓰게 한다.";
"move.desc.19" = "기술을 썼을 때 공격을 받으면 분노의 힘으로 공격이 올라간다.";
"move.desc.20" = "날카로운 앞니로 강하게 물어서 공격한다. 상대의 HP는 절반이 된다.";
"move.desc.21" = "자신의 HP와 상대의 HP를 합친 것을 자신과 상대가 사이좋게 나눈다.";
"move.desc.23" = "입에서 뿜어낸 실을 휘감아서 상대의 스피드를 크게 떨어뜨린다.";
"move.desc.24" = "상대를 화내게 해서 혼란시킨다. 분노로 상대의 공격은 크게 올라가 버린다.";
"move.desc.25" = "자신이 잠들어 있을 때 소음을 내어 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.26" = "기분 좋은 방울소리를 들려주어 같은 편 전원의 상태 이상을 회복한다.";
"move.desc.27" = "그만 귀를 막아버리고 싶은 싫은 소리를 내어 상대의 방어를 크게 떨어뜨린다.";
"move.desc.28" = "작은 바위를 들어올려 상대에게 내던져서 공격한다.";
"move.desc.30" = "큰 바위를 세차게 부딪쳐서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.32" = "세차게 소용돌이치는 물속에 4-5턴 동안 상대를 가두어 공격한다.";
"move.desc.33" = "우는 척을 하며 눈물을 흘린다. 난처하게 만들어 상대의 특수방어를 크게 떨어뜨린다.";
"move.desc.34" = "기분 좋은 예쁜 노랫소리를 들려주고 상대를 잠듦 상태로 만든다.";
"move.desc.35" = "상대가 마지막으로 사용한 기술에 원한을 품어 그 기술의 PP를 4만큼 줄인다.";
"move.desc.36" = "날카로운 바람으로 상대를 베어 공격한다. 급소에 맞기 쉽다.";
"move.desc.37" = "연기나 먹물을 내뿜어 상대의 명중률을 떨어뜨린다.";
"move.desc.38" = "상대 포켓몬이 교체될 때 기술을 쓰면 2배의 위력으로 공격할 수 있다.";
"move.desc.39" = "연속 뺨치기로 상대를 때려서 공격한다. 2-5회 동안 연속으로 쓴다.";
"move.desc.40" = "상대가 사용한 기술을 흉내 내어 자신도 똑같은 기술을 쓴다.";
"move.desc.42" = "무지개색의 빔을 상대에게 발사하여 공격한다. 공격을 떨어뜨릴 때가 있다.";
"move.desc.43" = "자신은 기절하게 되지만 그 대신 상대의 공격과 특수공격을 크게 떨어뜨린다.";
"move.desc.44" = "상대의 얼굴 등에 먹물을 내뿜어 공격한다. 명중률을 떨어뜨릴 때가 있다.";
"move.desc.45" = "상대를 부추겨서 혼란시킨다. 동시에 상대의 특수공격도 올라가 버린다.";
"move.desc.46" = "큰 소리 등으로 불시에 놀래켜서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.47" = "으스스하고 괴상한 불꽃을 쏘아 상대를 화상 상태로 만든다.";
"move.desc.49" = "상대의 기술로 기절하면 원념을 담아 그 기술의 PP를 0으로 만든다.";
"move.desc.51" = "상대로부터 받은 물리공격의 데미지를 2배로 만들어 같은 상대에게 돌려준다.";
"move.desc.52" = "불꽃을 둘러 상대에게 돌진하여 공격한다. 화상 상태로 만들 때가 있다.";
"move.desc.53" = "세찬 불꽃을 상대에게 발사하여 공격한다. 화상 상태로 만들 때가 있다.";
"move.desc.54" = "고스트타입에 효과가 없는 기술이나 회피율이 높은 상대라 할지라도 공격이 맞게 된다.";
"move.desc.55" = "몸의 각을 늘려서 더욱 각지게 하여 자신의 공격을 올린다.";
"move.desc.56" = "재빠른 움직임으로 분신을 만들어 상대를 혼란시켜 회피율을 올린다.";
"move.desc.57" = "날개로 일으킨 격한 바람을 상대에게 부딪쳐서 공격한다.";
"move.desc.58" = "전신에 힘을 담아 몸을 단단하게 해서 자신의 방어를 올린다.";
"move.desc.59" = "상대의 움직임을 막아 바로 전에 쓴 기술을 4턴 동안 사용할 수 없게 만든다.";
"move.desc.60" = "바람의 칼날을 만들어 2턴째에 상대를 공격한다. 급소에 맞기 쉽다.";
"move.desc.61" = "2턴 동안 공격을 견뎌 입은 데미지를 2배로 만들어 상대에게 돌려준다.";
"move.desc.62" = "날카로운 이빨로 상대를 깨물어 부숴서 공격한다. 상대의 방어를 떨어뜨릴 때가 있다.";
"move.desc.63" = "날카롭고 뾰족한 이빨로 물어서 공격한다. 상대를 풀죽게 만들 때가 있다.";
"move.desc.64" = "강한 번개를 상대에게 떨어뜨려 공격한다. 마비 상태로 만들 때가 있다.";
"move.desc.65" = "전격을 담은 펀치로 상대를 공격한다. 마비 상태로 만들 때가 있다.";
"move.desc.66" = "상대의 HP가 자신의 HP와 같아지도록 데미지를 준다.";
"move.desc.68" = "날카로운 당수로 상대를 때려서 공격한다. 급소에 맞기 쉽다.";
"move.desc.69" = "매우 튼튼하고 두꺼운 껍질에 4-5턴 동안 상대를 끼워서 공격한다.";
"move.desc.70" = "껍질에 숨어 몸을 보호하여 자신의 방어를 올린다.";
"move.desc.71" = "촉수나 덩굴 등을 휘감아서 공격한다. 상대의 스피드를 떨어뜨릴 때가 있다.";
"move.desc.72" = "수도로 기세 좋게 내려쳐서 상대를 공격한다. 빛의장막이나 리플렉터 등도 파괴할 수 있다.";
"move.desc.73" = "암석을 내던져서 공격한다. 상대의 움직임을 봉인함으로써 스피드를 떨어뜨린다.";
"move.desc.74" = "깊게 숨을 들이마셔 기합을 넣는다. 자신의 공격이 급소에 맞기 쉬워진다.";
"move.desc.76" = "양분을 흡수하여 공격한다. 입힌 데미지의 절반에 해당하는 HP를 회복할 수 있다.";
"move.desc.77" = "힘을 쥐어짜서 공격한다. 자신의 HP가 적을수록 기술의 위력이 올라간다.";
"move.desc.79" = "최면 효과가 있는 포자를 훌훌 흩뿌려서 상대를 잠듦 상태로 만든다.";
"move.desc.80" = "피를 빨아서 상대를 공격한다. 준 데미지의 절반을 HP로 회복한다.";
"move.desc.81" = "발톱이나 낫 등으로 상대를 베어 갈라서 공격한다. 급소에 맞기 쉽다.";
"move.desc.82" = "바람에 날개 가루를 날려서 상대를 공격한다. 자신의 모든 능력이 올라갈 때가 있다.";
"move.desc.83" = "금속을 긁을 때 나는 듯한 싫은 소리를 들려준다. 상대의 특수방어를 크게 떨어뜨린다.";
"move.desc.84" = "기분 좋은 피리 소리를 들려주어 상대를 잠듦 상태로 만든다.";
"move.desc.85" = "몸을 간질여 웃게 만들어서 상대의 공격과 방어를 떨어뜨린다.";
"move.desc.86" = "끈적끈적하고 가는 실을 칭칭 휘감아 상대를 배틀에서 도망칠 수 없게 한다.";
"move.desc.87" = "큰 집게를 상대에게 내리쳐서 공격한다. 급소에 맞기 쉽다.";
"move.desc.88" = "흑안개를 뿜어 배틀에 참가 중인 포켓몬 전원의 능력 변화를 원래대로 돌린다.";
"move.desc.89" = "빨려 들어갈 것 같은 까만 눈빛으로 가만히 응시하여 상대를 배틀에서 도망갈 수 없게 한다.";
"move.desc.90" = "양손으로 당수를 상대에게 힘껏 쳐서 공격한다. 급소에 맞기 쉽다.";
"move.desc.91" = "2-3턴 동안 마구 난동 부려서 공격한다. 난동 부린 뒤에는 혼란에 빠진다.";
"move.desc.92" = "발을 강하게 걸고 상대를 넘어뜨려 공격한다. 상대가 무거울수록 위력이 올라간다.";
"move.desc.93" = "원시의 힘으로 공격한다. 자신의 모든 능력이 오를 때가 있다.";
"move.desc.94" = "자신의 HP를 회복한다. 날씨에 따라 회복량이 변한다.";
"move.desc.95" = "힘을 빼고 몸을 가볍게 해서 고속으로 움직인다. 자신의 스피드를 크게 올린다.";
"move.desc.96" = "회전해서 상대를 공격한다. 조이기, 김밥말이, 씨뿌리기 등을 날려버린다. 자신의 스피드도 오른다.";
"move.desc.97" = "차가운 냉기를 상대에게 내뿜어 공격한다. 상대의 스피드를 떨어뜨린다.";
"move.desc.98" = "상대의 움직임을 마음으로 읽고 다음 공격이 반드시 상대에게 명중되게 한다.";
"move.desc.99" = "우주로부터 신비한 힘을 손에 넣음으로써 자신의 방어와 특수방어를 올린다.";
"move.desc.100" = "2턴째에 상대를 공격한다. 가끔 풀죽게 만든다. 급소에도 맞기 쉽다.";
"move.desc.101" = "차가운 가랑눈을 상대에게 내뿜어 공격한다. 얼음 상태로 만들 때가 있다.";
"move.desc.102" = "자신에게 주목시켜 상대로부터의 공격을 모두 자신에게 향하게 한다.";
"move.desc.103" = "혜성과 같은 펀치를 날려서 상대를 공격한다. 자신의 공격이 올라갈 때가 있다.";
"move.desc.104" = "공격을 받아도 HP를 반드시 1만큼은 남긴다. 연속으로 쓰면 실패하기 쉽다.";
"move.desc.105" = "5턴 동안 구르기를 반복하여 공격한다. 기술이 맞을 때마다 위력이 올라간다.";
"move.desc.106" = "무서운 얼굴로 노려보고 겁주어 상대의 스피드를 크게 떨어뜨린다.";
"move.desc.107" = "이상한 광선을 상대에게 발사하여 공격한다. 혼란시킬 때가 있다.";
"move.desc.108" = "이상한 염력파를 상대에게 발사하여 공격한다. 사용할 때마다 데미지가 바뀐다.";
"move.desc.109" = "강한 염동력을 상대에게 보내어 공격한다. 상대의 특수방어를 떨어뜨릴 때가 있다.";
"move.desc.111" = "졸음을 유도하는 암시를 걸어서 상대를 잠듦 상태로 만든다.";
"move.desc.112" = "3턴 동안 소란 피워 공격한다. 그동안은 아무도 잠들지 않게 된다.";
"move.desc.114" = "이상한 빛을 발사해서 공격한다. 상대를 혼란시킬 때가 있다.";
"move.desc.115" = "자신에게 암시를 걸어서 능력 변화 상태를 상대와 똑같은 상태로 만든다.";
"move.desc.116" = "땅에 자신과 함께 상대를 내던져 공격한다. 자신도 조금 데미지를 입는다.";
"move.desc.117" = "세포를 재생시켜 자신의 최대 HP의 절반만큼 HP를 회복한다.";
"move.desc.118" = "지진의 충격으로 자신의 주위에 있는 포켓몬을 공격한다.";
"move.desc.120" = "긴 혀로 상대를 핥아서 공격한다. 마비 상태로 만들 때가 있다.";
"move.desc.121" = "바둥바둥 난동 부려서 공격한다. 자신의 HP가 적을수록 기술의 위력이 올라간다.";
"move.desc.122" = "꼬리를 좌우로 귀엽게 흔들어 방심을 유도한다. 상대의 방어를 떨어뜨린다.";
"move.desc.123" = "폭발을 일으켜서 자신의 주위에 있는 포켓몬을 공격한다. 쓰고 나서 기절하게 된다.";
"move.desc.124" = "저리가루를 많이 흩뿌려서 상대를 마비 상태로 만든다.";
"move.desc.125" = "긴 몸이나 덩굴 등을 써서 4-5턴 동안 상대를 조여 공격한다.";
"move.desc.126" = "그림자에 섞여 펀치를 날린다. 공격은 반드시 명중한다.";
"move.desc.127" = "까만 그림자의 덩어리를 내던져서 공격한다. 상대의 특수방어를 떨어뜨릴 때가 있다.";
"move.desc.128" = "다음 턴에 쓸 전기타입 기술의 위력을 올린다. 자신의 특수방어도 올라간다.";
"move.desc.129" = "강한 전격을 상대에게 날려서 공격한다. 마비 상태로 만들 때가 있다.";
"move.desc.130" = "하얀 안개로 몸을 덮는다. 5턴 동안 상대에 의해 능력이 떨어지지 않게 된다.";
"move.desc.131" = "땅이 갈라진 곳에 상대를 떨어뜨려 공격한다. 맞으면 일격에 기절한다.";
