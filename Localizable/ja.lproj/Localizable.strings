"move.desc.1" = "硬い　しっぽで相手を　たたきつけて　攻撃する。相手の　防御を　さげることが　ある。";
"move.desc.3" = "大きな　あくびで　眠気を　誘う。次の　ターンに相手を　眠り状態に　する。";
"move.desc.4" = "恐ろしい　顔で　キスを　せまる。相手を　眠り状態に　する。";
"move.desc.5" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.6" = "自分の　ＨＰを　回復する。天気に　よって回復の　量が　変化する。";
"move.desc.7" = "相手より　あとに　攻撃する。そのかわり　自分の　攻撃は必ず　命中する。";
"move.desc.8" = "１ターン目に　潜り　２ターン目で相手を　攻撃する。";
"move.desc.9" = "２ー３ターンの　間暴れまくって　相手を　攻撃する。暴れたあとは　混乱する。";
"move.desc.10" = "香りで　相手の　回避率をがくっと　さげる。";
"move.desc.11" = "かわいく　みつめて　油断を　誘い相手の　攻撃を　がくっと　さげる。";
"move.desc.12" = "５ターンの　間　雨を　降らせてみずタイプの　威力を　あげる。ほのおタイプの　威力は　さがる。";
"move.desc.13" = "怪しい　光を相手に　みせて　まどわせる。相手を　混乱させる。";
"move.desc.14" = "５ターンの　間　あられを　降らしてこおりタイプで　ない　ポケモン全員に　ダメージを　与える。";
"move.desc.15" = "心地好い　やすらぐ　香りを　かがせて味方全員の　状態異常を　回復する。";
"move.desc.16" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.17" = "相手に　アンコールした　技を３回　続けて　出させる。";
"move.desc.19" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.20" = "鋭い　前歯で激しく　かみついて　攻撃する。相手の　ＨＰは　半分に　なる。";
"move.desc.21" = "自分の　ＨＰと　相手の　ＨＰをあわせて　それを　自分と　相手でなかよく　わける。";
"move.desc.23" = "口から　吹きだした糸を　まきつけて　相手の素早さを　がくっと　さげる。";
"move.desc.24" = "相手を　怒らせて　混乱させる。怒りで　相手の　攻撃はぐーんと　あがってしまう。";
"move.desc.25" = "自分が　寝ているときに雑音を　だして　攻撃する。相手を　ひるませることが　ある。";
"move.desc.26" = "心地好い　鈴の　音色を　聞かせて味方　全員の状態異常を　回復　する。";
"move.desc.27" = "おもわず　耳を　ふさぎたくなるいやなおとを　だして相手の　防御を　がくっと　さげる。";
"move.desc.28" = "小さな　岩を　持ちあげて相手に　投げつけて　攻撃する。";
"move.desc.30" = "大きな　岩を激しく　ぶつけて　攻撃する。相手を　ひるませることが　ある。";
"move.desc.32" = "激しく　渦をまく　水の中に４ー５ターンの　間相手を　閉じこめて　攻撃する。";
"move.desc.33" = "ないた　ふりをして　涙を　流す。こまらせる　ことで相手の　特防を　がくっと　さげる。";
"move.desc.34" = "心地好い　きれいな歌声を　聞かせて相手を　眠り状態に　する。";
"move.desc.35" = "相手が　最後に　使った技に恨みを　抱いてその技の　ＰＰを　４だけ　減らす。";
"move.desc.36" = "鋭い　風で相手を　切りつけて　攻撃する。急所に　当たりやすい。";
"move.desc.37" = "煙や　墨などを　吹きかけて相手の　命中率を　さげる。";
"move.desc.38" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.39" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.40" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.42" = "にじいろの　ビームを相手に　発射して　攻撃する。攻撃を　さげる　ことが　ある。";
"move.desc.43" = "自分は　ひんしに　なるが　そのかわりに相手の　攻撃と　特攻をがくっと　さげる。";
"move.desc.44" = "相手の　顔などに墨を　吹きかけて　攻撃する。命中率を　さげることが　ある。";
"move.desc.45" = "相手を　おだてて　混乱させる。同時に　相手の　特攻もあげてしまう。";
"move.desc.46" = "大きな　声などで不意に　驚かして　攻撃する。相手を　ひるませることが　ある。";
"move.desc.47" = "不気味で　怪しい　炎を　放って相手を　やけどの　状態に　する。";
"move.desc.49" = "相手の　技で　ひんしに　されたときおんねんを　かけてその技の　ＰＰを　０に　する。";
"move.desc.51" = "相手から　受けた　物理攻撃のダメージを　２倍に　して同じ　相手に　返す。";
"move.desc.52" = "炎を　まとい相手に　突進して　攻撃する。やけど状態に　することが　ある。";
"move.desc.53" = "激しい　炎を相手に　発射して　攻撃する。やけど状態に　することが　ある。";
"move.desc.54" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.55" = "この技は　使えません思い出すことが　できなくなりますが技を　忘れることを　おすすめします";
"move.desc.56" = "素早い　動きで　分身を　つくり相手を　まどわせて回避率を　あげる。";
